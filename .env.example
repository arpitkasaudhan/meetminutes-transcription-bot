# ── Required ──────────────────────────────────────────────────────────────────

# Groq API key for Whisper transcription (free tier: https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Backend HTTP / WS port
PORT=3000

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379

# URL the Playwright bot uses to reach the backend WebSocket
# Inside Docker this should be http://backend:3000
BACKEND_WS_URL=http://localhost:3000

# Frontend: backend URL visible to the browser (must be reachable from client)
VITE_BACKEND_URL=http://localhost:3000
